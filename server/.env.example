# Local development only. Copy to server/.env and fill in your key, then:
#   cd server && npm install && npm run dev
# (Cloud Run does NOT use this file — deploy.sh stores the key in Secret Manager.)
GEMINI_API_KEY=your-aistudio-key-here
# Optional local overrides:
# ALLOWED_ORIGINS=*
# DAILY_VOICE_CAP=3000
# PER_IP_PER_MIN=20
