rules_version = '2';
// The Imitation Gate — Firestore security rules.
// All writes go through the Cloud Run service account (which bypasses these
// rules via Admin SDK). Direct client access is denied: players cannot forge
// scores or read raw documents from the browser. The leaderboard is only ever
// reachable through the server's validated /api/leaderboard endpoint.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
